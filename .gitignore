# Ignore everything by default
*

# Allow git tracking files
!.gitignore

# Allow .claude folder (agents + commands/skills)
!.claude/
!.claude/agents/
!.claude/agents/**
!.claude/commands/
!.claude/commands/**

# Allow Agent output folder
!Agent/
!Agent/output/
!Agent/output/**

# Allow PDF export script
!cv_to_pdf.py

# Ignore generated PDFs (large binary, not needed in repo)
*.pdf
